Options -Indexes

<FilesMatch "(^\.|^\.env|^\.git|composer\.json|composer\.lock|rules\.md|README\.md)">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(data|config|_backup|vendor|node_modules)(/|$) - [F,L]
    RewriteRule \.(sqlite|sqlite3|db|bak|log|tmp)$ - [F,L]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-Robots-Tag "noindex, nofollow, noarchive"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Content-Security-Policy "frame-ancestors 'none'; base-uri 'self'; object-src 'none'"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"
</IfModule>
